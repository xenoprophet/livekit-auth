# Murmur ZeroC Ice endpoint
# Must match the "ice=" line in murmur.ini, e.g.:
#   ice=tcp -h 127.0.0.1 -p 6502
MURMUR_ICE_HOST=127.0.0.1
MURMUR_ICE_PORT=6502

# Ice read/write secret — must match icesecretwrite= in murmur.ini
# Leave blank if Murmur is not configured with a secret.
MURMUR_ICE_SECRET=

# Murmur virtual server ID (almost always 1)
MURMUR_SERVER_ID=1

# Host our callback OA listens on — must be reachable by Murmur.
CALLBACK_HOST=127.0.0.1

# Shared secret — clients must send:
#   Authorization: Bearer <API_SECRET>
API_SECRET=changeme

# SQLite database file path
DB_PATH=./messages.db

# Page size limits
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=500
